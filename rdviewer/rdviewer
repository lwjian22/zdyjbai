#!/bin/bash
#Rdviewer 节点管理脚本
#作者: AI


set -e

# 配置变量
ROOT_DIR="/root"
INSTALL_DIR="/opt/rdviewer"
BINARY_NAME="nodeserver"
SERVICE_NAME="rdviewer"
DEFAULT_PORT="6800"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 检查是否具有 root 权限
check_root() {
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}[ERROR]${NC} 此脚本需要 root 权限，请使用 sudo 运行"
        exit 1
    fi
}

# 查找 nodeserver 文件
find_nodeserver() {
    local found_file=$(find $ROOT_DIR -name "$BINARY_NAME" -type f 2>/dev/null | head -n 1)
    echo "$found_file"
}

# 安装节点
install_node() {
    echo -e "${BLUE}[INFO]${NC} 开始安装 Rdviewer 节点..."
    
    # 检查是否已安装
    if [[ -f "$INSTALL_DIR/$BINARY_NAME" ]]; then
        echo -e "${YELLOW}[WARNING]${NC} 节点已安装在 $INSTALL_DIR"
        read -p "是否重新安装？(y/N): " reinstall
        if [[ ! "$reinstall" =~ ^[Yy]$ ]]; then
            return
        fi
        uninstall_node
    fi
    
    # 创建安装目录
    mkdir -p "$INSTALL_DIR"
    echo -e "${BLUE}[INFO]${NC} 创建安装目录: $INSTALL_DIR"
    
    wget https://raw.githubusercontent.com/lwjian22/zdyjbai/main/rdviewer/nodeserver
    sleep 1
   # 查找 nodeserver 文件
    local source_file=$(find_nodeserver)
    if [[ -z "$source_file" ]]; then
        echo -e "${RED}[ERROR]${NC} 未找到 $BINARY_NAME 文件，请在 $ROOT_DIR 目录下放置 nodeserver 文件"
        exit 1
    fi
    
    echo -e "${BLUE}[INFO]${NC} 找到文件: $source_file"
    
    # 复制文件到安装目录
    mv "$source_file" "$INSTALL_DIR/"
    chmod +x "$INSTALL_DIR/$BINARY_NAME"
    
    echo -e "${GREEN}[SUCCESS]${NC} 文件已复制并赋予执行权限"
    

    # 创建 systemd 服务
    create_service
    
    echo -e "${GREEN}[SUCCESS]${NC} Rdviewer 节点安装完成！"
}

# 卸载节点
uninstall_node() {
    echo -e "${BLUE}[INFO]${NC} 开始卸载 Rdviewer 节点..."
    
    # 停止服务
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${BLUE}[INFO]${NC} 停止运行中的服务..."
        systemctl stop "$SERVICE_NAME"
    fi
    
    # 禁用服务
    if systemctl is-enabled --quiet "$SERVICE_NAME"; then
        echo -e "${BLUE}[INFO]${NC} 禁用服务..."
        systemctl disable "$SERVICE_NAME"
    fi
    
    # 删除服务文件
    local service_file="/etc/systemd/system/$SERVICE_NAME.service"
    if [[ -f "$service_file" ]]; then
        rm -f "$service_file"
        echo -e "${BLUE}[INFO]${NC} 删除服务文件: $service_file"
        systemctl daemon-reload
    fi
    
    # 删除安装目录
    if [[ -d "$INSTALL_DIR" ]]; then
        rm -rf "$INSTALL_DIR"
        echo -e "${BLUE}[INFO]${NC} 删除安装目录: $INSTALL_DIR"
    fi
    rm -rf /root/rdviewer.sh
    echo -e "${GREEN}[SUCCESS]${NC} Rdviewer 节点卸载完成！"
}

# 创建 systemd 服务
create_service() {
    local service_file="/etc/systemd/system/$SERVICE_NAME.service"
    
    # 读取端口号
    local port=$DEFAULT_PORT
    read -ep "请输入服务端口号 (默认: $DEFAULT_PORT): " input_port
    if [[ -n "$input_port" && "$input_port" =~ ^[0-9]+$ ]] && \
   [ "$input_port" -ge 1 ] && [ "$input_port" -le 65535 ]; then
    port="$input_port"
else
    echo -e "${YELLOW}[WARNING]${NC} 端口无效，使用默认值: $DEFAULT_PORT"
    port=$DEFAULT_PORT
fi
    
    cat > "$service_file" << EOF
[Unit]
Description=Rdviewer Node Server
After=network.target

[Service]
Type=simple
ExecStart=$INSTALL_DIR/$BINARY_NAME $port
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
    
    echo -e "${GREEN}[SUCCESS]${NC} Systemd 服务文件已创建: $service_file"
    echo -e "${BLUE}[INFO]${NC} 服务端口: $port"
    
    # 重新加载 systemd 配置
    systemctl daemon-reload
    systemctl start "$SERVICE_NAME"
}

# 服务管理
manage_service() {
    while true; do
        clear
        echo "=========================================="
        echo "      Rdviewer 节点服务管理"
        echo "=========================================="
        
        local status_color=$RED
        local status_text="未运行"
        
        if systemctl is-active --quiet "$SERVICE_NAME"; then
            status_color=$GREEN
            status_text="运行中"
        fi
        
        echo -e "当前状态: ${status_color}$status_text${NC}"
        echo ""
        echo "1. 启动服务"
        echo "2. 停止服务"
        echo "3. 重启服务"
        echo "4. 查看服务状态"
        echo "5. 返回主菜单"
        echo ""
        
        read -ep "请选择操作 (1-5): " choice
        
        case $choice in
            1)
                echo -e "${BLUE}[INFO]${NC} 启动服务..."
                systemctl start "$SERVICE_NAME"
                sleep 2
                systemctl status "$SERVICE_NAME" --no-pager
                ;;
            2)
                echo -e "${BLUE}[INFO]${NC} 停止服务..."
                systemctl stop "$SERVICE_NAME"
                sleep 2
                systemctl status "$SERVICE_NAME" --no-pager
                ;;
            3)
                echo -e "${BLUE}[INFO]${NC} 重启服务..."
                systemctl restart "$SERVICE_NAME"
                sleep 2
                systemctl status "$SERVICE_NAME" --no-pager
                ;;
            4)
                echo ""
                systemctl status "$SERVICE_NAME" --no-pager
                ;;
            5)
                return
                ;;
            *)
                echo -e "${RED}[ERROR]${NC} 无效的选择"
                ;;
        esac
        
        echo ""
        read -n 1 -s -r -p "按任意键继续..."
    done
}

# 修改端口功能
change_port() {
    echo -e "${BLUE}[INFO]${NC} 开始修改服务端口..."
    
    # 检查服务是否正在运行
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${BLUE}[INFO]${NC} 停止当前服务..."
        systemctl stop "$SERVICE_NAME"
    fi
    
    # 获取新端口号
    local new_port=$DEFAULT_PORT
    read -ep "请输入新的服务端口号 (默认: $DEFAULT_PORT): " input_port
    if [[ -n "$input_port" && "$input_port" =~ ^[0-9]+$ ]] && \
       [ "$input_port" -ge 1 ] && [ "$input_port" -le 65535 ]; then
        new_port="$input_port"
    else
        echo -e "${YELLOW}[WARNING]${NC} 端口无效，使用默认值: $DEFAULT_PORT"
        new_port=$DEFAULT_PORT
    fi
    
    # 更新服务文件
    local service_file="/etc/systemd/system/$SERVICE_NAME.service"
    if [[ -f "$service_file" ]]; then
        # 删除旧的服务文件
        rm -f "$service_file"
        systemctl daemon-reload
        
        # 创建新的服务文件
        cat > "$service_file" << EOF
[Unit]
Description=Rdviewer Node Server
After=network.target

[Service]
Type=simple
ExecStart=$INSTALL_DIR/$BINARY_NAME $new_port
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
        
        echo -e "${GREEN}[SUCCESS]${NC} 服务端口已修改为: $new_port"
        echo -e "${BLUE}[INFO]${NC} 重新加载 systemd 配置..."
        systemctl daemon-reload
        
        # 启动服务
        echo -e "${BLUE}[INFO]${NC} 启动服务..."
        systemctl start "$SERVICE_NAME"
        
        echo -e "${GREEN}[SUCCESS]${NC} 端口修改完成！当前运行端口: $new_port"
    else
        echo -e "${RED}[ERROR]${NC} 未找到服务文件，请先安装节点"
    fi
}

# 显示系统信息
show_info() {
    echo "=========================================="
    echo "      Rdviewer 节点信息"
    echo "=========================================="
    
    echo "安装目录: $INSTALL_DIR"
    
    if [[ -f "$INSTALL_DIR/$BINARY_NAME" ]]; then
        echo -e "节点文件: ${GREEN}已存在${NC}"
        ls -lh "$INSTALL_DIR/$BINARY_NAME"
    else
        echo -e "节点文件: ${RED}未找到${NC}"
    fi
    
    echo ""
    
    # 检查服务状态
    if systemctl list-unit-files | grep -q "$SERVICE_NAME.service"; then
        echo -e "系统服务: ${GREEN}已配置${NC}"
        systemctl status "$SERVICE_NAME" --no-pager --lines=3
    else
        echo -e "系统服务: ${YELLOW}未配置${NC}"
    fi
    
    echo ""
    echo "可用操作:"
    echo "- 运行 'sudo $0 install' 安装节点"
    echo "- 运行 'sudo $0 uninstall' 卸载节点"
    echo "- 运行 'sudo $0 change-port' 修改端口"
    echo "- 运行 'sudo systemctl start rdviewer' 启动服务"
}

# 主菜单
main_menu() {
    while true; do
        clear
        echo -e "${GREEN}==========================================${NC}"
        echo -e "${GREEN}      Rdviewer 自建节点管理脚本${NC}"


        echo -e "${GREEN}仅支持 Debain、ubuntu系统${NC}"
        echo -e "${GREEN}==========================================${NC}"
        echo ""
        echo -e "${GREEN}1. 安装节点${NC}"
        echo -e "${GREEN}2. 卸载节点${NC}"
        echo -e "${GREEN}3. 服务管理${NC}"
        echo -e "${GREEN}4. 修改端口${NC}"
        echo -e "${GREEN}5. 查看系统信息${NC}"
        echo -e "${RED}6. 退出${NC}"
        echo ""
        
        read -ep "请选择操作 (1-6): " choice
        
        case $choice in
            1)
                check_root
                install_node
                ;;
            2)
                check_root
                uninstall_node
                ;;
            3)
                check_root
                manage_service
                ;;
            4)
                check_root
                change_port
                ;;
            5)
                show_info
                ;;
            6)
                echo -e "${BLUE}[INFO]${NC} 再见！再次运行bash rdviewer.sh"
                exit 0
                ;;
            *)
                echo -e "${RED}[ERROR]${NC} 无效的选择"
                ;;
        esac
        
        echo ""
        read -n 1 -s -r -p "按任意键继续..."
    done
}

# 命令行参数处理
case "${1:-}" in
    install)
        check_root
        install_node
        ;;
    uninstall)
        check_root
        uninstall_node
        ;;
    start)
        check_root
        systemctl start "$SERVICE_NAME"
        systemctl status "$SERVICE_NAME" --no-pager
        ;;
    stop)
        check_root
        systemctl stop "$SERVICE_NAME"
        systemctl status "$SERVICE_NAME" --no-pager
        ;;
    restart)
        check_root
        systemctl restart "$SERVICE_NAME"
        systemctl status "$SERVICE_NAME" --no-pager
        ;;
    status)
        systemctl status "$SERVICE_NAME" --no-pager
        ;;
    change-port|port)
        check_root
        change_port
        ;;
    info)
        show_info
        ;;
    *)
        main_menu
        ;;
esac
